{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Lucy Desktop",
  "version": "0.7.0-rc1",
  "identifier": "com.lucy.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lucy Desktop",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "icon": [
      "icons/icon.png"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Lucy Team. All rights reserved.",
    "category": "Utility",
    "shortDescription": "AI-Enhanced Pocket Multi-Tool Desktop Console",
    "longDescription": "Lucy Desktop is an AI-enhanced desktop companion for pocket multi-tool devices (ESP32-S3 + CC1101 + ST25R3916). Features include NFC read/write, Sub-GHz scan/TX, IR remote, BadUSB with 3-stage safety, GPIO, firmware management, virtual lab, audit center, and more.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["en-US", "zh-CN"],
        "displayLanguageSelector": true
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": ["https://releases.lucy.dev/latest.json"],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
