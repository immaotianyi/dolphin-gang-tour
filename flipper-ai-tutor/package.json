{
  "name": "flipper-ai-tutor",
  "version": "1.0.0",
  "description": "Dolphin Gang Tour - 适配 Flipper Zero 的手把手AI教学 & 一键资源导入（非官方产品）",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:win": "tauri build --target x86_64-pc-windows-gnu",
    "build:win-msvc": "tauri build --target x86_64-pc-windows-msvc",
    "build:mac": "npm run build && npm run tauri build -- --target aarch64-apple-darwin --bundles dmg",
    "build:mac:arm": "npm run tauri build -- --target aarch64-apple-darwin --bundles dmg",
    "build:mac:intel": "npm run tauri build -- --target x86_64-apple-darwin --bundles dmg",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "build:installers": "npm run build && tauri build",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "powershell -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1",
    "tauri:android:sign": "powershell -ExecutionPolicy Bypass -File scripts/sign-latest-android-apk.ps1",
    "release:github": "powershell -ExecutionPolicy Bypass -File scripts/publish-github-release.ps1",
    "release:github:all": "powershell -ExecutionPolicy Bypass -File scripts/publish-github-release.ps1 -AllVersions",
    "release:publish-all": "powershell -ExecutionPolicy Bypass -File scripts/publish-all-with-credential.ps1",
    "upload:all-installers": "python scripts/upload-all-installers.py",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "bash scripts/build-ios.sh",
    "tauri:ios:build:ci": "npm run build && npm run tauri ios init && npm run tauri ios build -- --debug --target aarch64-sim",
    "icon": "tauri icon src-tauri/icons/app-icon.png"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
